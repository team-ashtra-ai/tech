{
  "name": "rotata-static-growth-system",
  "version": "1.0.0",
  "private": true,
  "description": "Static-first, Cloudflare-hosted, WordPress-exportable premium website for Rotata.",
  "scripts": {
    "dev": "python3 scripts/dev.py 8000",
    "serve": "python3 -m http.server 8000 -d dist",
    "build": "python3 scripts/build_site.py && python3 scripts/generate_sitemap.py && python3 scripts/generate_schema.py",
    "validate": "python3 scripts/validate_links.py && python3 scripts/validate_seo.py",
    "lang:generate": "python3 scripts/generate_languages.py --to-langs es fr",
    "lang:generate:ollama": "python3 scripts/generate_languages.py --to-langs es fr --use-ollama",
    "lang:source:en": "python3 scripts/generate_languages.py --set-source-language en",
    "lang:source:es": "python3 scripts/generate_languages.py --set-source-language es",
    "lang:source:fr": "python3 scripts/generate_languages.py --set-source-language fr",
    "optimize:images": "python3 scripts/optimize_images.py",
    "og": "python3 scripts/generate_og_images.py",
    "wp:export": "python3 scripts/export_wordpress_theme.py",
    "wp:zip": "python3 scripts/create_wp_zip.py",
    "content:ideas": "python3 scripts/content_machine.py --ideas 10"
  },
  "engines": {
    "node": ">=20",
    "python": ">=3.11"
  },
  "license": "UNLICENSED"
}
